# AI provider selection: ollama | openai
AI_PROVIDER=ollama

# Ollama provider settings (used when AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# OpenAI provider settings (used when AI_PROVIDER=openai)
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional custom health endpoint. If empty, server defaults to <OPENAI_BASE_URL>/v1/models
OPENAI_HEALTH_URL=

# Optional timeout (milliseconds) used by AI health probes (/api/ai/health)
AI_HEALTH_TIMEOUT_MS=5000
# Optional debug mode to include raw LLM request/response payloads in explain/suggest API responses
AI_DEBUG_LLM_IO=false

# RAG backend selection: filesystem | qdrant
AI_RAG_BACKEND=filesystem

# Qdrant settings for RAG indexing/retrieval (used when AI_RAG_BACKEND=qdrant)
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=phpsage-rag

# Optional defaults for ingestion and retrieval context
AI_INGEST_DEFAULT_TARGET=/workspace/docs/phpstan
AI_RAG_DIRECTORY=docs/phpstan
AI_RAG_TOP_K=3
AI_RAG_AUTO_INGEST_ON_BOOT=false

# Public hostname used by the server-side Traefik override
PHPSAGE_PUBLIC_HOST=phpsage.example.com

# Origin certificate paths used by Traefik for Cloudflare Full (strict)
# Keep these files in a local certificates/ directory that stays out of git.
PHPSAGE_TLS_CERT_PATH=./certificates/cloudflare-origin.crt
PHPSAGE_TLS_KEY_PATH=./certificates/cloudflare-origin.key

# Optional deployment automation mode: git | local
PHPSAGE_DEPLOY_SOURCE=git
