# -------------------------------------------------------------------
# PHPSAGE INFRASTRUCTURE CONFIGURATION
# -------------------------------------------------------------------
# Copy this file to `.env` and fill in the required values.
#
# Example:
# cp .env.example .env
#
# Never commit `.env` with real credentials.
# -------------------------------------------------------------------

# -------------------------------------------------------------------
# Pulumi
# -------------------------------------------------------------------

# Pulumi access token for Pulumi Cloud
PULUMI_ACCESS_TOKEN=

# Only stack used in this phase
PULUMI_STACK=dev


# -------------------------------------------------------------------
# Hetzner Cloud
# -------------------------------------------------------------------

# Hetzner Cloud API token
HCLOUD_TOKEN=

# Server configuration
HCLOUD_SERVER_NAME=phpsage-dev

# Server type examples:
# cpx22
# cpx32
HCLOUD_SERVER_TYPE=cpx22

# Datacenter location examples:
# fsn1
# nbg1
# hel1
HCLOUD_LOCATION=hel1

# Base image
HCLOUD_IMAGE=ubuntu-24.04

# Path to your SSH public key
HCLOUD_SSH_PUBLIC_KEY_PATH=


# -------------------------------------------------------------------
# Cloudflare
# -------------------------------------------------------------------

# Cloudflare API token with permissions:
# - Zone DNS Edit
# - Account access (if using Zero Trust)
CLOUDFLARE_API_TOKEN=

# Cloudflare Zone ID of your domain
CLOUDFLARE_ZONE_ID=

# Cloudflare Account ID (required for Zero Trust Access resources)
CLOUDFLARE_ACCOUNT_ID=

# Root domain already managed in Cloudflare
CLOUDFLARE_DOMAIN=nopingnogain.com

# Subdomain used for PHPSage
CLOUDFLARE_SUBDOMAIN=phpsage


# -------------------------------------------------------------------
# Cloudflare behaviour
# -------------------------------------------------------------------

# Enable Cloudflare proxy (orange cloud)
ENABLE_CLOUDFLARE_PROXY=true

# Enable optional Cloudflare Zero Trust integration
ENABLE_ZERO_TRUST=false

# Comma-separated list of allowed emails when Zero Trust is enabled
ZERO_TRUST_ALLOWED_EMAILS=mouredev@gmail.com,jossemi@gmail.com,josemi.rodriguez@outlook.es


# -------------------------------------------------------------------
# Optional settings
# -------------------------------------------------------------------

# SSH user for server access
SSH_ALLOWED_USER=root


# -------------------------------------------------------------------
# Resulting domain example
# -------------------------------------------------------------------
# If:
# CLOUDFLARE_DOMAIN=example.com
# CLOUDFLARE_SUBDOMAIN=phpsage
#
# Final URL becomes:
#
# https://phpsage.example.com
#
# -------------------------------------------------------------------